# Copy to `.env` in this folder. Never commit `.env`.
#
# PostgreSQL on your home server (not Docker). Apply `backend/migrations/001_init_vaultspend.sql`
# once against database `bytecub` if the `vaultspend` schema is not there yet.

DATABASE_URL=postgres://bytecub_admin:YOUR_PASSWORD@192.168.1.8:30432/bytecub?sslmode=disable

API_PORT=8080

# Min 32 characters (required by the API).
JWT_SECRET=dev-change-me-use-32chars-minimum-secret-key
JWT_EXPIRY_HOURS=24
