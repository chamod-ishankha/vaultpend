# Run API on host (no Docker): export DATABASE_URL then `go run ./cmd/server`
#
# Home server example (password in YOUR_PASSWORD — do not commit real values):
# DATABASE_URL=postgres://bytecub_admin:YOUR_PASSWORD@192.168.1.8:30432/bytecub?sslmode=disable

HTTP_ADDR=:8080
JWT_SECRET=dev-change-me-use-32chars-minimum-secret-key
JWT_EXPIRY_HOURS=24
